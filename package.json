{
  "name": "bob.yexley.net",
  "description": "my personal web site",
  "type": "module",
  "scripts": {
    "refresh": "rm -rf node_modules && rm -f pnpm-lock.yaml && pnpm install",
    "compile": "tsc",
    "lint": "eslint src/ --cache",
    "test": "vitest run",
    "test:watch": "vitest",
    "quality-check": "concurrently --kill-others-on-fail --names \"tsc,eslint\" --prefix-colors \"auto,auto\" \"pnpm compile\" \"pnpm lint\" --color",
    "qc": "pnpm quality-check",
    "db:start": "pnpm exec supabase start",
    "db:stop": "pnpm exec supabase stop",
    "db:status": "pnpm exec supabase status",
    "db:reset": "pnpm exec supabase db reset",
    "db:pull": "pnpm exec supabase db pull",
    "db:push:local": "pnpm exec supabase db push --local",
    "db:push:remote": "pnpm exec supabase db push --linked",
    "db:diff": "pnpm exec supabase db diff",
    "db:migration:new": "pnpm exec supabase migration new",
    "db:migration:list": "pnpm exec supabase migration list",
    "db:types": "mkdir -p src/types && pnpm exec supabase gen types typescript --local > src/types/database.types.ts",
    "db:bootstrap:superuser": "node ./scripts/bootstrap-local-superuser.mjs",
    "db:bootstrap:visitors": "node ./scripts/bootstrap-local-fixtures.mjs --mode=visitors",
    "db:bootstrap:fixtures": "node ./scripts/bootstrap-local-fixtures.mjs --mode=all",
    "db:reset:fixtures": "pnpm db:reset && pnpm db:bootstrap:fixtures",
    "dev": "node --env-file=.env.local ./node_modules/vinxi/bin/cli.mjs dev --port 7808 --host",
    "dev:app": "node --env-file=.env.local ./node_modules/vinxi/bin/cli.mjs dev --port 7808 --host",
    "dev:local": "node --env-file=.env.local ./node_modules/vinxi/bin/cli.mjs dev --port 7808 --host",
    "build": "vinxi build",
    "start": "node --env-file=.env.local ./node_modules/vinxi/bin/cli.mjs start",
    "component:add": "pnpm dlx shadcn-solid add"
  },
  "dependencies": {
    "@cookbook/solid-intl": "^0.1.2",
    "@corvu/drawer": "^0.2.4",
    "@formatjs/intl": "^4.1.2",
    "@kobalte/core": "^0.13.11",
    "@milkdown/core": "^7.19.0",
    "@milkdown/plugin-emoji": "^7.19.0",
    "@milkdown/plugin-listener": "^7.19.0",
    "@milkdown/plugin-slash": "^7.19.0",
    "@milkdown/preset-commonmark": "^7.19.0",
    "@milkdown/prose": "^7.19.0",
    "@milkdown/theme-nord": "^7.19.0",
    "@milkdown/utils": "^7.19.0",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.3",
    "@solidjs/start": "^1.1.4",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.57.4",
    "@unpic/solid": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fontfaceobserver": "^2.3.0",
    "marked": "^17.0.3",
    "micromark-extension-mark": "^1.0.2",
    "solid-js": "^1.9.7",
    "solid-transition-group": "^0.3.0",
    "tailwind-merge": "^3.3.1",
    "vinxi": "^0.5.7",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@corvu/tailwind": "^0.1.7",
    "@kobalte/tailwindcss": "^0.9.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.1.10",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.5.3",
    "supabase": "^2.90.0",
    "tailwindcss": "^4.1.10",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.3",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@corvu/tailwind>tailwindcss": "*",
        "@kobalte/tailwindcss>tailwindcss": "*"
      }
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "supabase",
      "@tailwindcss/oxide",
      "esbuild"
    ]
  }
}
